# .ai-upstream/ is a LOCAL staging area: safe-copy upstream skills here, then
# promote/adapt into .github/ (canon). Not version-controlled. See .ai-upstream/.gitkeep
.ai-upstream/*
!.ai-upstream/.gitkeep

# .github/.ai-upstream/ tracks only the required-vendor-skill manifest; the
# manually-installed vendor skill folders stay untracked (kept verbatim).
.github/.ai-upstream/*
!.github/.ai-upstream/README.md
