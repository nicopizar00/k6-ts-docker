{
  "name": "k6-ts-docker",
  "services": {
    "gateway-api": { "type": "http", "port": 3000 },
    "catalog-api": { "type": "http", "port": 3001 },
    "orders-api": { "type": "http", "port": 3002 },
    "postgres": { "type": "postgres", "port": 5432, "env": { "POSTGRES_PASSWORD": "${POSTGRES_PASSWORD}" } },
    "k6": { "type": "load-test", "tool": "k6" }
  },
  "notes": "Use environment variables for secrets. This file is for local Copilot/MCP tooling — do not store real credentials here."
}
