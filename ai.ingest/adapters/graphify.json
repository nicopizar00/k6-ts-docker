{
  "schema_version": 1,
  "name": "graphify",
  "skill_protocol": "agent-skills",
  "identity": {
    "upstream_repo": "https://github.com/safishamsi/graphify",
    "distribution": "pypi:graphifyy",
    "cli": ["graphify", "graphify-mcp"],
    "entrypoint": "SKILL.md",
    "version_kind": "pypi"
  },
  "install": {
    "method": "uv tool install graphifyy",
    "upgrade": "uv tool install --upgrade graphifyy",
    "fallback": "pip install graphifyy"
  },
  "verify": {
    "import_check": ["python", "-c", "import graphify"],
    "version_probe": ["graphify", "--version"],
    "version_marker_file": ".graphify_version"
  },
  "assets": {
    "upstream_snapshot_root": ".ai-upstream/graphify/",
    "adaptation_root": ".github/skills/punch-graphify/",
    "track_globs": ["SKILL.md", "references/**/*.md", ".graphify_version"]
  },
  "outputs": {
    "root": "graphify-out/",
    "evidence": ["graph.json", "GRAPH_REPORT.md", "graph.html"],
    "cache": ["cost.json", ".graphify_python", ".graphify_root", ".graphify_*.json"],
    "gitignored": true,
    "exclude_from_drift": true
  },
  "adaptation": {
    "kind": "leaned-fork",
    "removed_upstream_features": [
      "remote-repo clone + cross-repo merge (references/github-and-merge.md)",
      "media transcription / Whisper (references/transcribe.md)",
      "external exports: wiki/SVG/GraphML/obsidian, Neo4j/FalkorDB push (references/exports.md)",
      "MCP server",
      "/graphify add <url> and --watch daemon — external URL fetch + background auto-rebuild (references/add-watch.md)",
      "graphify claude install — always-on CLAUDE.md integration + post-commit auto-rebuild hook (references/hooks.md)"
    ],
    "expected_absent_references": ["exports.md", "github-and-merge.md", "transcribe.md", "add-watch.md", "hooks.md"]
  },
  "governance": {
    "adr": "docs/ai/decisions/0002-graphify-host-tool.md",
    "apply_requires_review": true
  }
}
